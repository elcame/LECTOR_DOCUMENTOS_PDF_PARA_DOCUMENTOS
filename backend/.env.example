# Flask Configuration
FLASK_ENV=production
SECRET_KEY=tu-secret-key-super-seguro-aqui

# Firebase Configuration
# En Cloud Run, usa Secret Manager para las credenciales
# No incluyas el archivo JSON directamente
GOOGLE_APPLICATION_CREDENTIALS=/secrets/firebase-credentials.json

# CORS Configuration
FRONTEND_URL=https://tu-proyecto.web.app

# Session Configuration
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=86400

# Upload Configuration
MAX_CONTENT_LENGTH=104857600
UPLOAD_FOLDER=/tmp/uploads
